{
  "expo": {
    "name": "rydnex",
    "slug": "rydnex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rydnex",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.bobosoftware.rydnex"
    },
    "android": {
      "backgroundColor": "#0A0A0B",
      "package": "com.bobosoftware.rydnex"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "backgroundColor": "#0A0A0B"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.692632366924-0ufuj8nf07k14ddbrdvkud8fi4jsea3a"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "48f25a0f-a630-40cb-bbde-595bfe06051f"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/48f25a0f-a630-40cb-bbde-595bfe06051f"
    }
  }
}
