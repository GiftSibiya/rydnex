# Google OAuth — see google-oauth-integration.md
# Web client (OAuth type "Web application", client_type 3 in google-services.json)
EXPO_PUBLIC_WEB_CLIENT_ID=

# iOS client (OAuth type "iOS")
EXPO_PUBLIC_IOS_CLIENT_ID=

# Android client (for reference; native build uses google-services.json)
EXPO_PUBLIC_ANDROID_CLIENT_ID=
